// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model KategoriPagu {
  id            String   @id @default(cuid())
  nama          String // Nama pagu (Pos Relawan, Pos Galon, Pos BBM, dll)
  anggaranDasar Decimal  @default(15000000) // Default: Rp15.000.000
  warna         String? // Warna untuk tampilan UI
  ikon          String? // Nama ikon dari lucide-react
  urutan        Int      @default(0) // Urutan tampilan
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transaksi               Transaksi[]
  anggaranKategoriPeriode AnggaranKategoriPeriode[]

  @@map("kategori_pagu")
}

model PeriodeAnggaran {
  id           String   @id @default(cuid())
  nama         String? // Nama/label periode (e.g., "Januari 2026", "Period 1")
  tanggalMulai DateTime // Tanggal mulai periode
  tanggalAkhir DateTime // Tanggal akhir periode (durasi 14 hari)
  isActive     Boolean  @default(false) // Menandai periode yang sedang aktif
  templateType String? // 'biweekly', 'monthly', 'quarterly', 'custom'
  notes        String? // Catatan user untuk periode ini
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transaksi               Transaksi[]
  anggaranKategoriPeriode AnggaranKategoriPeriode[]

  @@unique([tanggalMulai, tanggalAkhir])
  @@index([isActive])
  @@index([templateType])
  @@map("periode_anggaran")
}

model Transaksi {
  id         String   @id @default(cuid())
  tanggal    DateTime // Tanggal transaksi
  deskripsi  String // Deskripsi/jenis transaksi
  jumlah     Decimal // Jumlah pembelian
  kategoriId String
  periodeId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  kategori KategoriPagu    @relation(fields: [kategoriId], references: [id], onDelete: Cascade)
  periode  PeriodeAnggaran @relation(fields: [periodeId], references: [id], onDelete: Cascade)

  @@index([kategoriId])
  @@index([periodeId])
  @@index([tanggal])
  @@map("transaksi")
}

model AnggaranKategoriPeriode {
  id         String  @id @default(cuid())
  kategoriId String
  periodeId  String
  anggaran   Decimal

  kategori KategoriPagu    @relation(fields: [kategoriId], references: [id], onDelete: Cascade)
  periode  PeriodeAnggaran @relation(fields: [periodeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kategoriId, periodeId])
  @@index([kategoriId])
  @@index([periodeId])
  @@map("anggaran_kategori_periode")
}
